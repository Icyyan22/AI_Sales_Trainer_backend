# LLM Configuration (required)
TRAINER_LLM_MODEL=openai/gpt-4o          # LiteLLM model ID, e.g. openai/gpt-4o, openai/gemini-3-flash-preview
TRAINER_LLM_API_KEY=sk-your-api-key      # API key for the LLM provider
TRAINER_LLM_API_BASE=https://api.openai.com/v1  # Base URL (use proxy URL if needed)

# Lite model for evaluator / attitude judge / context compression (optional, falls back to main model)
# TRAINER_LITE_MODEL=openai/gpt-4o-mini

# Auth (optional)
# TRAINER_JWT_SECRET=change-me-in-production   # Auto-generated if not set
# TRAINER_SUPER_ADMIN_USERNAME=admin           # First registered user auto-becomes super_admin if not set
